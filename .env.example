# ============================================
# AEOlab 환경변수 템플릿
# .env.example → .env.local (프론트엔드)
# .env.example → backend/.env (백엔드)
# ============================================

# Supabase (https://supabase.com 에서 생성)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # 서버 전용 — 절대 클라이언트 노출 금지

# AI API Keys
GEMINI_API_KEY=AIzaSy...               # Google AI Studio
OPENAI_API_KEY=sk-proj-...             # OpenAI Platform
ANTHROPIC_API_KEY=sk-ant-...           # Anthropic Console
PERPLEXITY_API_KEY=pplx-...            # Perplexity API
GROK_API_KEY=xai-...                   # xAI Console

# 토스페이먼츠 (개발 환경: test_ 접두사)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# 카카오 알림톡
KAKAO_APP_KEY=...
KAKAO_SENDER_KEY=...

# 서버 설정
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
SECRET_KEY=change-this-to-random-32-char-string

# 관리자
ADMIN_SECRET_KEY=change-this-admin-key         # /admin 페이지 접근 키
NEXT_PUBLIC_ADMIN_KEY=                         # 프론트엔드 관리자 자동 로그인 (선택)

# Slack 오류 알림 (선택)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
