                    </ul>
                    <Link
                      href={startupPlan.href}
                      className="block text-center py-3 rounded-xl font-semibold text-base bg-amber-500 text-white hover:bg-amber-600 transition-colors"
                    >
                      {startupPlan.cta}
                    </Link>
                  </div>
                </div>
              </div>
            );
          })()}

          <p className="text-center text-sm text-gray-400 mb-3">
