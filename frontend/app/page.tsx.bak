      {/* ── 최종 CTA 배너 — 경쟁 심리 재자극 ── */}
      <section className="bg-blue-600 py-10 md:py-16 px-4 md:px-6">
        <div className="max-w-3xl mx-auto text-center text-white">
          <p className="text-sm md:text-base text-blue-200 mb-3 font-medium">지금 무료로 확인해보세요</p>
          <h2 className="text-2xl sm:text-3xl lg:text-4xl font-bold mb-4 break-keep">
